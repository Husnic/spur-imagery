# ─────────────────────────────────────────
# Spur Imagery — Environment Variables
# Copy this file to .env.local and fill in values.
# Never commit .env.local to version control.
# ─────────────────────────────────────────

# Public site URL (no trailing slash)
# Used for canonical URLs, OG metadata, and email auto-reply links
NEXT_PUBLIC_SITE_URL=https://spurimagery.com

# ── SMTP / Email ──────────────────────────
# Credentials for sending booking notification emails via nodemailer

# SMTP server host
# Examples: smtp.zoho.com | smtp.gmail.com | mail.privateemail.com
SMTP_HOST=smtp.zoho.com

# SMTP port — 465 for SSL/TLS, 587 for STARTTLS
SMTP_PORT=465

# SMTP auth — the email account used to send
SMTP_USER=hello@spurimagery.com
SMTP_PASSWORD=your_smtp_password_here

# The "From" address shown on outbound emails
SMTP_FROM=Spur Imagery <hello@spurimagery.com>

# Where booking notifications are delivered (the studio inbox)
CONTACT_EMAIL=spurimagery@gmail.com
